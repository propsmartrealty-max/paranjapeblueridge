{
  "name": "blue-ridge-sovereign",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "npx tsx scripts/verify-schemas.ts && NODE_OPTIONS='--max-old-space-size=8192' next build",
    "postbuild": "tsx scripts/generateSitemap.ts && tsx scripts/generateContentSitemap.ts && npx tsx scripts/trigger-indexnow.ts || echo 'IndexNow skipped'",
    "start": "next start",
    "lint": "next lint",
    "lhci:collect": "lhci collect",
    "lhci:assert": "lhci assert",
    "lhci:upload": "lhci upload",
    "lhci": "npm run lhci:collect && npm run lhci:assert && npm run lhci:upload",
    "test": "jest",
    "sitemap": "tsx scripts/generateSitemap.ts",
    "content": "tsx scripts/generateContentSitemap.ts"
  },
  "dependencies": {
    "@next/third-parties": "^14.2.3",
    "@types/dompurify": "^3.0.5",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.4",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.2.4",
    "googleapis": "^173.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.378.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.3.0",
    "vercel": "^54.1.0", "next-mdx-remote": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.5.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "jest": "^29.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "ts-jest": "^29.1.0",
    "jest-environment-jsdom": "^29.0.0",
    "remark-gfm": "^3.0.1",
    "rehype-slug": "^5.1.0",
    "rehype-autolink-headings": "^6.1.1"
  
  }
}
