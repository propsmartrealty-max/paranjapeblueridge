All rights reserved | ©2026 Paranjape Schemes Construction Limited,Managed and Marketed By : <a href="http://animotionsz.com/" class="text-dark" target="_new"><b>AnimotionsZ</b></a></div></div></div></div></div></div></div></footer> <script type="speculationrules">{"prefetch":[{"source":"document","where":{"and":[{"href_matches":"/*"},{"not":{"href_matches":["/wp-*.php","/wp-admin/*","/wp-content/uploads/*","/wp-content/*","/wp-content/plugins/*","/wp-content/themes/hello-elementor/*","/*\\?(.+)"]}},{"not":{"selector_matches":"a[rel~=\"nofollow\"]"}},{"not":{"selector_matches":".no-prefetch, .no-prefetch a"}}]},"eagerness":"conservative"}]}</script> <script type="text/javascript">jQuery(document).ready(function($){
        function loadProperties(page = 1) {
            $('#paged').val(page);
            var formData = $('#property-filter-form').serialize();

            $.ajax({
                url: 'https://www.pscl.in/wp-admin/admin-ajax.php',
                type: 'POST',
                data: {
                    action: 'property_filter',
                    ...Object.fromEntries(new URLSearchParams(formData))
                },
                beforeSend: function() {
                    $('#property-results').html('<p>Loading...</p>');
                    $('#property-pagination').html('');
                },
                success: function(response) {
                    var res = JSON.parse(response);
                    $('#property-results').html(res.html);
                    $('#property-pagination').html(res.pagination);
                }
            });
        }

        function loadBhkOptions(location) {
            var category = $('input[name="category"]').val();
            $.ajax({
                url: 'https://www.pscl.in/wp-admin/admin-ajax.php',
                type: 'POST',
                data: {
                    action: 'get_bhk_options',
                    location: location,
                    category: category
                },
                success: function(response) {
                    $('#bhk-select').html(response);
                }
            });
        }

        // Location change → update BHK + reload
        $('#location-select').on('change', function(){
            var location = $(this).val();
            loadBhkOptions(location);
            loadProperties(1);
        });

        // BHK change → reload
        $('#bhk-select').on('change', function(){
            loadProperties(1);
        });

        // Pagination click
        $(document).on('click', '.pagination-btn', function(){
            var page = $(this).data('page');
            loadProperties(page);
        });

        // Initial load
        loadProperties();
    });</script> <div data-elementor-type="popup" data-elementor-id="18289" class="elementor elementor-18289 elementor-location-popup" data-elementor-settings="{&quot;entrance_animation&quot;:&quot;fadeIn&quot;,&quot;exit_animation&quot;:&quot;fadeIn&quot;,&quot;entrance_animation_duration&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:0.5,&quot;sizes&quot;:[]},&quot;a11y_navigation&quot;:&quot;yes&quot;,&quot;timing&quot;:[]}" data-elementor-post-type="elementor_library"><div class="elementor-element elementor-element-6681b92 e-flex e-con-boxed e-con e-parent" data-id="6681b92" data-element_type="container" data-e-type="container"><div class="e-con-inner"><div class="elementor-element elementor-element-5387345 elementor-widget elementor-widget-html" data-id="5387345" data-element_type="widget" data-e-type="widget" data-widget_type="html.default"><form id="enquiryForm" class="custom-lead-form">
<label>Project:</label>
