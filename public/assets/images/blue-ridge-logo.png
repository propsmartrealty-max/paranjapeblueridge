  function replaceText(node) {
    if (node.nodeType === 3) { // Text node
      let text = node.textContent;

      // Convert Rs. to ₹
      text = text.replace(/\bRs\.?\s?/g, '₹ ');

      // Existing replacements
      text = text
        .replace(/\bHinjewadi\b/g, 'Hinjawadi')
        .replace(/\bPSCL\b/g, 'Paranjape Schemes Construction Limited')
        .replace(/\bSechdule\b/g, 'Schedule')
        .replace(/\bBhk\b/g, 'BHK')
        .replace(/\bLakhs\b/g, 'Lakh')
        .replace(/\bAnand\b/g, 'Ananda');

      // Add ₹ only if it's not already present immediately before the number
      text = text.replace(/(?<!₹\s?)(?<!\d\.)\b(\d+(?:\.\d+)?\s*(Lakh|Cr\.?|Crore))\b/g, '₹ $1');

      // Remove comma before 'and' and fix spacing
      text = text.replace(/\s*,\s*and\b/g, ' and');

      node.textContent = text;
    } else if (node.nodeType === 1 && node.nodeName !== "SCRIPT" && node.nodeName !== "STYLE") {
      for (let child of node.childNodes) {
        replaceText(child);
      }
    }
  }

  replaceText(document.body);

  // Handle dynamically added content
  const observer = new MutationObserver(mutations => {
    for (const mutation of mutations) {
      for (const node of mutation.addedNodes) {
        replaceText(node);
      }
    }
  });
  observer.observe(document.body, { childList: true, subtree: true });
});</script><script>// Inject CSS for hidden class
const style = document.createElement("style");
style.textContent = `
  .dialog-type-lightbox.hidden {
    display: none !important;
  }
`;
document.head.appendChild(style);

// Toggle logic
document.addEventListener("click", (e) => {
  const plusIcon = e.target.closest(".icon-toggle .plus-icon");
  const closeIcon = e.target.closest(".icon-toggle .close-icon");

  if (plusIcon) {
    document.querySelectorAll(".dialog-type-lightbox").forEach(el => {
      el.classList.remove("hidden");
    });
  }

  if (closeIcon) {
    document.querySelectorAll(".dialog-type-lightbox").forEach(el => {
      el.classList.add("hidden");
    });
  }
});</script><link rel="icon" href="https://www.pscl.in/wp-content/uploads/2025/11/cropped-P-Factor-SVG-32x32.png" sizes="32x32" /><link rel="icon" href="https://www.pscl.in/wp-content/uploads/2025/11/cropped-P-Factor-SVG-192x192.png" sizes="192x192" /><link rel="apple-touch-icon" href="https://www.pscl.in/wp-content/uploads/2025/11/cropped-P-Factor-SVG-180x180.png" /><meta name="msapplication-TileImage" content="https://www.pscl.in/wp-content/uploads/2025/11/cropped-P-Factor-SVG-270x270.png" /><style id="wp-custom-css">html {
  overflow-x: hidden !important;
}

body{
	overflow-x: visible !important;
	
	overflow: visible !important;
}




/* Smooth transitions for logo and other icons */
.logo, .navigation, #icon1, #icon2, #myIcon, #myIcon2 {
  transition: filter 0.25s ease, fill 0.25s ease, stroke 0.25s ease;
}

/* --- Default: light background → logo brand color (#b14136) --- */

#blur-nav .logo svg rect {
  stroke: #B14136;
}


#blur-nav .logo svg path{
  fill: #B14136;
}

/* --- Dark background → logo turns white --- */

#blur-nav.invert .logo svg rect {
  stroke: #fff;
}

#blur-nav.invert .logo svg path{
  fill: #fff;
}

/* --- Other Icons + Navigation Invert --- */
#blur-nav.invert .navigation,
#blur-nav.invert #icon1,
#blur-nav.invert #icon2,
#blur-nav.invert #myIcon,
#blur-nav.invert #myIcon2 {
  filter: invert(1);
}



@media (max-width: 767px) {
  html, body {
    overflow-x: hidden !important;
  }
}


#acf-filters label {
    display: block;
    font-size: 14px;
    margin: 10px 0 5px;
    color: #888;
}

.filter-dropdown {
    width: 100%;
    border: none;
    border-bottom: 1px solid #ccc;
    padding: 8px;
    background: transparent;
    font-size: 16px;
    outline: none;
    appearance: none;
}

.filter-dropdown:focus {
    border-bottom: 2px solid #000;
}


.my-border-btn-red a:hover{
	background-color: #C44A3E !important;
	color: #fff !important;
}

.my-border-btn-red a:hover svg path{
	fill: #fff !important;
}

.my-border-btn-white a:hover{
	background-color: #B14136 !important;
	color: #fff !important;
}

.my-border-btn-white a:hover svg {
	fill: #fff !important;
}

.my-border-btn-black a:hover{
	color: black !important; 
	border: 1px solid #000 !important;
	background-color: transparent !important;
}

.my-border-btn a:hover{
	color: #fff !important; 
	border: 1px solid #fff !important;
}

.my-border-btn a:hover svg{
	fill: #fff !important;
}

/* career page roles and responsibility section */
.careers-roles-listing {
  display: grid;
  gap: 20px;
  grid-template-columns: repeat(8, 1fr);
}

.careers-roles-listing ul {
  grid-column: span 4;
}

/* On mobile */
@media (max-width: 768px) {
  .careers-roles-listing {
    grid-template-columns: 1fr; /* Only one column */
  }

  .careers-roles-listing ul {
    grid-column: 1 / -1; /* Span the full width */
  }
}


