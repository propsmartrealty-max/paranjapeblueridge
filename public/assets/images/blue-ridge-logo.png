/* --- Containers --- */
.tab-container {
  position: absolute;          
  top: 0; left: 0; width: 100%;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .4s ease, visibility .4s ease, background-color .6s ease; /* added bg */
  background-color: #ffffff; /* set your base bg */
}
.tab-container.active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  z-index: 2;
  background-color: #f5f5f5; /* target bg when active */
}

.tab-headings .tab-heading { 
  cursor: pointer; 
  transition: color .3s ease; /* smooth change */
}

.tab-heading.active-heading { 
  font-weight: 600; 
  color: #000; /* black when active */
}

.tab-heading.active-heading a{
    color: #000 !important;
}
.tab-heading a{
    display: block;
    padding: 5px 0px;
}

.tab-heading.active-heading a{
    transition: all 0.5s ease;
}

.tab-heading:hover {
  color: #000; /* black on hover too */
}

.tab-wrapper .active-heading{
    background: url('https://www.paranjapeschemes.co.in/wp-content/uploads/2025/09/desktop-menu-arrow.svg') 90% center no-repeat !important;
    color: #000000 !important;
}



.inner-heading a:hover::before {
    display: block;
    position: absolute;
    height: 100%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    border: 1px solid transparent;
    left: 0px;
    top: 10px;
    font-size: 60px;
    content: '';
    background: #ffffff;
}

#c2 .inner-heading a:hover::before{
    background: #000;
}

#c6 .inner-heading a:hover::before{
    background: #000;
}

#c7 .inner-heading a:hover::before{
    background: #000;
}

#c8 .inner-heading a:hover::before{
    background: #000;
}

.inner-heading a{
    transition: all 0.5s ease;
}

.inner-heading a:hover{
    padding-left: 12px;
}

/* outer headings */
.tab-headings .tab-heading{ cursor: pointer; }
.tab-heading.active-heading{ font-weight: 600; }

/* --- Inner images --- */
.inner-img {
  opacity: 0;
  visibility: hidden;
  position: absolute;
  top: 0; left: 0; width: 100%;
  transition: opacity .35s ease, visibility .35s ease;
}
.inner-img.active {
  opacity: 1;
  visibility: visible;
  z-index: 1;
}
.inner-heading { cursor: pointer; }

/* Wrap all containers in a relatively positioned parent */
.tab-containers-wrapper {
  position: relative;
  width: 100%;
  min-height: 300px; /* adjust for your design */
}</style> <script>(function(){
  document.addEventListener('DOMContentLoaded', function(){
    var headings   = document.querySelectorAll('.tab-heading');
    var containers = document.querySelectorAll('.tab-container');
    var defaultContainer = document.getElementById('default');

    if(headings.length === 0 || containers.length === 0) return;

    // Reset all
    containers.forEach(function(c){ c.classList.remove('active'); });
    if(defaultContainer) defaultContainer.classList.add('active');
    else if(containers[0]) containers[0].classList.add('active');

    // helper to show a container by id
    function showContainerById(id){
      containers.forEach(function(c){ c.classList.remove('active'); });
      var el = document.getElementById(id);
      if(el) el.classList.add('active');
    }

    // Reset to default
    function resetToDefault(){
      containers.forEach(function(c){ c.classList.remove('active'); });
      if(defaultContainer) defaultContainer.classList.add('active');
      headings.forEach(function(x){ x.classList.remove('active-heading'); });
    }

    // Outer headings hover/click
    headings.forEach(function(h){
      var targetId = h.getAttribute('data-target') || (h.id && h.id.indexOf('tab-') === 0 ? h.id.replace(/^tab-/, '') : null);
      if(!targetId) return;

      var relatedContainer = document.getElementById(targetId);

      h.addEventListener('mouseenter', function(){
        showContainerById(targetId);
        headings.forEach(function(x){ x.classList.remove('active-heading'); });
        h.classList.add('active-heading');
      });

      h.addEventListener('click', function(e){
        const link = e.target.closest('a');
        // ✅ Allow real links to work normally
        if (link && link.getAttribute('href') && link.getAttribute('href') !== '#') {
          return;
        }
        // Otherwise handle tab switching
        showContainerById(targetId);
        e.preventDefault();
      });

      // Reset only when leaving BOTH heading + container
      function setupReset(el){
        el.addEventListener('mouseleave', function(ev){
          var related = (el === h) ? relatedContainer : h;
          if(related && related.contains(ev.relatedTarget)) return;
          resetToDefault();
        });
      }
      setupReset(h);
      if(relatedContainer) setupReset(relatedContainer);
    });

    // Optional: click outside everything -> reset
    document.addEventListener('click', function(ev){
      if(!ev.target.closest('.tab-heading') && !ev.target.closest('.tab-container')){
        resetToDefault();
      }
    });

    /* ============ INNER LIST → IMAGE LOGIC ============ */
    containers.forEach(function(container){
      var innerHeadings = container.querySelectorAll('.inner-heading');
      var innerImages   = container.querySelectorAll('.inner-img');

      if(innerHeadings.length && innerImages.length){
        var defaultImg = innerImages[0]; // fallback default

        function showImageById(id){
          innerImages.forEach(function(img){ img.classList.remove('active'); });
          var target = container.querySelector('#' + id);
          (target || defaultImg).classList.add('active');
        }

        innerHeadings.forEach(function(h){
          h.addEventListener('mouseenter', function(){
            var imgId = h.getAttribute('data-img');
            if(imgId) showImageById(imgId);
          });

          h.addEventListener('click', function(e){
            const link = e.target.closest('a');
            // ✅ Allow links to behave normally
            if (link && link.getAttribute('href') && link.getAttribute('href') !== '#') {
              return;
            }

            var imgId = h.getAttribute('data-img');
            if(imgId) showImageById(imgId);
            e.preventDefault();
          });
        });

        // Reset to default image when leaving this container
        container.addEventListener('mouseleave', function(){
          innerImages.forEach(function(img){ img.classList.remove('active'); });
          if(defaultImg) defaultImg.classList.add('active');
        });

        // init default image
        if(defaultImg) defaultImg.classList.add('active');
      }
    });
    /* ================================================== */

  });
})();</script> </div></div></div></div></div></div></div></div></div></div></div></div><div class="elementor-element elementor-element-1e38562 my-border-btn-red elementor-hidden-desktop elementor-hidden-tablet elementor-hidden-mobile elementor-widget elementor-widget-button" data-id="1e38562" data-element_type="widget" data-e-type="widget" data-widget_type="button.default">
