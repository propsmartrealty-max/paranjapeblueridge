s/brochures/THE-ORCHARD-RESIDENCES-A3-PRESENTER_v7.pdf">The Orchard Residencies</option><option value="canopy" data-brochure="https://www.pscl.in/wp-content/uploads/brochures/The-Canopy-Brochure_V2.pdf">Canopy</option><option value="gloria-grand" data-brochure="https://www.pscl.in/wp-content/uploads/brochures/Gloria-Grand-Brochure.pdf">Gloria Grand</option><option value="shrivega" data-brochure="https://www.pscl.in/wp-content/uploads/brochures/Shrivega-Brochure.pdf">Shrivega</option><option value="forest-trails">Forest Trails</option><option value="promenade-residences" data-brochure="https://www.pscl.in/wp-content/uploads/brochures/The-Promenade-Brochure.pdf">Promenade Residences</option><option value="swaniketan" data-brochure="https://www.pscl.in/wp-content/uploads/brochures/SWANIKETAN-BROCHURE.pdf">Swaniketan</option><option value="athashri-vadodara" data-brochure="https://www.pscl.in/wp-content/uploads/brochures/Athashri-Vadodra-Ph-Brochure.pdf">Athashri Vadodara</option><option value="cove-residences">Cove Residences</option>
</select><input type="text" id="EnqFirstName" placeholder="Full Name" required>
<input type="email" id="EnqEmail" placeholder="Email" required>
<input type="tel" id="EnqMobileNo" placeholder="Mobile No" required><br><br><button type="button" id="btnEnqOnly">Submit</button></form> <script>(function () {
  const ajaxUrl = "/wp-admin/admin-ajax.php";
  
  document.addEventListener("DOMContentLoaded", function () { if (window.preselectedProject) { const sel = document.getElementById("projectEnq"); sel.value = window.preselectedProject; sel.style.display = "none"; console.log("📌 Auto-selected Enquiry project:", window.preselectedProject); } });

  function sendEnquiry() {
    const projectSel = document.getElementById("projectEnq");
    const project = window.preselectedProject || projectSel.value;
    const FirstName = document.getElementById("EnqFirstName").value.trim();
    const Email = document.getElementById("EnqEmail").value.trim();
    const MobileNo = document.getElementById("EnqMobileNo").value.trim();

    if (!project || !FirstName || !Email || !MobileNo) {
      alert("Please fill all required fields.");
      return;
    }

    // ⭐ Get brochure URL from selected option
    const brochureUrl = projectSel.options[projectSel.selectedIndex].dataset.brochure;

    const fd = new FormData();
    fd.append("action", "send_to_mdocbox");
    fd.append("project", project);
    fd.append("dataFrom", "E");
    fd.append("FirstName", FirstName);
    fd.append("Email", Email);
    fd.append("MobileNo", MobileNo);

    fetch(ajaxUrl, { method: "POST", body: fd })
      .then(r => r.json())
      .then(data => {

        console.log("📩 Enquiry Response:", data);

        if (data.decoded?.status === "success") {
          alert("✅ Enquiry Lead Submitted!");
          document.getElementById("enquiryForm").reset();

          // ⭐ Open the brochure in new tab
          if (brochureUrl) {
            window.open(brochureUrl, "_blank");
          }

        } else {
          alert("⚠️" + (data.decoded?.message || "Email or Mobile already used"));
        }
      });
  }

  document.getElementById("btnEnqOnly")
    .addEventListener("click", sendEnquiry);
})();</script> </div></div></div></div><div data-elementor-type="popup" data-elementor-id="14986" class="elementor elementor-14986 elementor-location-popup" data-elementor-settings="{&quot;entrance_animation&quot;:&quot;slideInDown&quot;,&quot;exit_animation&quot;:&quot;slideInDown&quot;,&quot;entrance_animation_duration&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:0.5,&quot;sizes&quot;:[]},&quot;prevent_close_on_background_click&quot;:&quot;yes&quot;,&quot;prevent_close_on_esc_key&quot;:&quot;yes&quot;,&quot;prevent_scroll&quot;:&quot;yes&quot;,&quot;entrance_animation_mobile&quot;:&quot;slideInDown&quot;,&quot;exit_animation_mobile&quot;:&quot;slideInDown&quot;,&quot;timing&quot;:[]}" data-elementor-post-type="elementor_library"><div class="elementor-element elementor-element-1591f12 e-flex e-con-boxed e-con e-parent" data-id="1591f12" data-element_type="container" data-e-type="container" data-settings="{&quot;background_background&quot;:&quot;classic&quot;}"><div class="e-con-inner"><div class="elementor-element elementor-element-8b20d69 e-con-full e-flex e-con e-child" data-id="8b20d69" data-element_type="container" data-e-type="container"><div class="elementor-element elementor-element-7e00915 elementor-icon-list--layout-traditional elementor-list-item-link-full_width elementor-widget elementor-widget-icon-list" data-id="7e00915" data-element_type="widget" data-e-type="widget" data-widget_type="icon-list.default"><ul class="elementor-icon-list-items"><li class="elementor-icon-list-item">
