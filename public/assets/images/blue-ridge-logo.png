</search></div></div></div></li></ul></div></nav></div><div class="elementor-element elementor-element-d654454 elementor-widget__width-initial elementor-widget elementor-widget-html" data-id="d654454" data-element_type="widget" data-e-type="widget" data-widget_type="html.default"> <script>document.addEventListener('DOMContentLoaded', function () {
  const container = document.getElementById('blur-nav');
  const dropdownBtn = document.getElementById('e-n-menu-dropdown-icon-6351');
  const icon3 = document.getElementById('icon1');           // optional
  const navMenu = document.querySelector('nav.e-n-menu');
  const dropMenus = document.querySelectorAll('.drop-menu');

  if (!container || !dropdownBtn) return;

  function applyState(isOpen) {
    if (isOpen) {
      container.classList.add('active');
      if (navMenu) navMenu.classList.add('hidden');
      dropMenus.forEach(drop => drop.classList.add('hidden'));

      dropdownBtn.style.backgroundColor = 'white';
      if (icon3) icon3.style.display = 'none';
    } else {
      container.classList.remove('active');
      if (navMenu) navMenu.classList.remove('hidden');
      dropMenus.forEach(drop => drop.classList.remove('hidden'));

      dropdownBtn.style.backgroundColor = '';
      if (icon3) icon3.style.display = 'inline-block';
    }
  }

  // initialize from current state
  applyState(dropdownBtn.getAttribute('aria-expanded') === 'true');

  // Robust: react when aria-expanded actually changes
  const mo = new MutationObserver(() => {
    applyState(dropdownBtn.getAttribute('aria-expanded') === 'true');
  });
  mo.observe(dropdownBtn, { attributes: true, attributeFilter: ['aria-expanded'] });

  // Fallback: also check just after click (runs after other handlers)
  dropdownBtn.addEventListener('click', () => {
    setTimeout(() => {
      applyState(dropdownBtn.getAttribute('aria-expanded') === 'true');
    }, 0);
  });
});</script> </div><div class="elementor-element elementor-element-895dbba elementor-widget__width-initial elementor-widget elementor-widget-html" data-id="895dbba" data-element_type="widget" data-e-type="widget" data-widget_type="html.default"> <script>document.addEventListener("DOMContentLoaded", function () {
  const icon1 = document.getElementById("icon1"); // open icon
  const icon2 = document.getElementById("icon2"); // close icon
  const offCanvas = document.getElementById("off-canvas-8933d66");

  if (icon1 && icon2 && offCanvas) {
    function updateIcons() {
      const isHidden = offCanvas.getAttribute("aria-hidden") === "true";

      // Update icons
      icon1.setAttribute("aria-hidden", isHidden ? "false" : "true");
      icon2.setAttribute("aria-hidden", isHidden ? "true" : "false");

      // Handle inert + margin + z-index
      if (isHidden) {
        offCanvas.setAttribute("inert", "");
        offCanvas.style.zIndex = "-1";
        offCanvas.style.marginTop = ""; // reset
      } else {
        offCanvas.removeAttribute("inert");
        offCanvas.style.zIndex = "";
        offCanvas.style.marginTop = "72px"; // ✅ add margin only when open
      }
    }

    // Run once at load
    updateIcons();

    // Open canvas on icon1 click
    icon1.addEventListener("click", function () {
      offCanvas.setAttribute("aria-hidden", "false");
      updateIcons();
    });

    // Close canvas on icon2 click
    icon2.addEventListener("click", function () {
      offCanvas.setAttribute("aria-hidden", "true");
      updateIcons();
    });

    // Sync with Elementor
    const observer = new MutationObserver(updateIcons);
    observer.observe(offCanvas, { attributes: true, attributeFilter: ["aria-hidden"] });
  }
});

document.addEventListener("DOMContentLoaded", function () {
  const trigger = document.getElementById("e-n-menu-title-2142");
  const offCanvas = document.getElementById("off-canvas-8933d66");

  if (trigger && offCanvas) {
    function updateOffCanvasState() {
      const isHidden = offCanvas.getAttribute("aria-hidden") === "true";
      if (isHidden) {
        offCanvas.setAttribute("aria-hidden", "false");
        offCanvas.removeAttribute("inert");
        offCanvas.style.marginTop = "72px"; // ✅ add margin when open
      } else {
        offCanvas.setAttribute("aria-hidden", "true");
        offCanvas.setAttribute("inert", "");
        offCanvas.style.marginTop = ""; // reset when closed
      }
    }

    trigger.addEventListener("click", function (e) {
      e.preventDefault();
      updateOffCanvasState();
    });

    const observer = new MutationObserver(function () {
      const isHidden = offCanvas.getAttribute("aria-hidden") === "true";
      if (isHidden) {
        offCanvas.setAttribute("inert", "");
        offCanvas.style.marginTop = "";
      } else {
        offCanvas.removeAttribute("inert");
        offCanvas.style.marginTop = "72px";
      }
    });
    observer.observe(offCanvas, { attributes: true, attributeFilter: ["aria-hidden"] });
  }
});






document.addEventListener("DOMContentLoaded", function () {
  const myIcon1 = document.getElementById("myIcon1");
  const menuToggle = document.getElementById("menu-toggle-635"); // specific menu toggle

  if (myIcon1 && menuToggle) {
    myIcon1.addEventListener("click", function (e) {
      e.preventDefault();
      // Only toggle this specific menu
      menuToggle.click();
    });
