/* ==============================
   Sticky Menu Dropdown Fix
   ============================== */
@media (max-width: 768px) {
/* Prevent Elementor built-in animation */
.e-n-menu-content.animated,
.e-n-menu-content.undefined {
  animation: none !important;
  transition: none !important;
}

/* Keep dropdown out of layout to avoid flicker */
.e-n-menu-content {
  position: absolute !important;
  bottom: 50%;        /* above sticky menu */
  left: 0;
  width: 100%;
	height: 220px !important;
  opacity: 0;
  transform: translateY(-5px);
  pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
  z-index: 9999;
}

	#e-n-menu-content-2601{
		bottom: 120% !important;
		position: absolute !important;
	}

/* Active dropdown state */
.e-n-menu-content.e-active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* Force GPU rendering on sticky menu to prevent flicker */
.elementor-sticky--active {
  transform: translateZ(0);
  backface-visibility: hidden;
  will-change: transform;
  height: 60px; /* Adjust to your sticky menu height */
}

/* Optional: Smooth fade for nested items */
.e-n-menu-content * {
  transition: inherit;
}

/* Apply equal padding to all menu items in this specific menu */
#e-n-menu-content-2601 .e-n-menu-item {
  padding-top: 6px;
  padding-bottom: 6px;
	display: block;
  width: 100%;
}

	#e-n-menu-content-2601 .e-n-menu-item:last-child .e-n-menu-title.e-anchor {
  border: none !important;
  padding: 0 !important;
}

.elementor-element.elementor-element-f8be473.e-n-menu-none.e-full_width.e-n-menu-layout-horizontal.elementor-widget.elementor-widget-n-menu {
  min-height: 44px !important;
  max-height: 44px !important;
	display: flex;
  align-items: center; /* vertically centers content */
}


/* Default (inactive) state */
.e-n-menu-title-2601 {
  color: #ffffff67 !important;
}

.e-n-menu-title-2601 svg path {
  fill: #ffffff67 !important;
}

/* Active state */
.e-n-menu-title-2601.active,
.e-n-menu-title-2601.e-active,
.e-n-menu-title-2601.current-menu-item {
  color: #fff !important;
}

.e-n-menu-title-2601.active svg path,
.e-n-menu-title-2601.e-active svg path,
.e-n-menu-title-2601.current-menu-item svg path {
  fill: #fff !important;
}
	svg.e-font-icon-svg.e-fas-caret-down path{
		fill: #ffffff67 !important;
	}

	svg.e-font-icon-svg.e-fas-caret-up path{
		fill: #fff !important;
	}

}

