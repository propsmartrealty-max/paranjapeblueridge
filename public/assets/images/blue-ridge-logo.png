//# sourceURL=https://www.pscl.in/wp-includes/js/wp-emoji-loader.min.js</script> <style>/* Initial hidden state */
.fade-in-element {
  opacity: 0;
  transition: opacity 2s ease;
}

/* Visible state */
.fade-in-element.visible {
  opacity: 1;
}</style> <script>document.addEventListener('DOMContentLoaded', () => {
  const allElements = document.querySelectorAll('h1, h2, h4, h5, h6, img, p,');

  allElements.forEach(el => {
    // Skip excluded containers (carousels, sliders, navigation, off-canvas, etc.)
    if (
      el.closest(
        '.off-canvas, .loop-grid, .loop-carousel, .elementor-swiper, .swiper-container, .swiper-slide, .slick-slider, .slick-track, nav, .no-fade, h3'
      )
    ) return;

    // Skip paragraphs on small screens (mobile)
    if (el.tagName.toLowerCase() === 'p' && window.innerWidth < 768) return;

    el.classList.add('fade-in-element');
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target); // animate only once
      }
    });
  }, { threshold: 0.5 }); // trigger when 20% is visible

  document.querySelectorAll('.fade-in-element').forEach(el => observer.observe(el));
});</script> <script>document.addEventListener('DOMContentLoaded', function () {
    const nav = document.getElementById('blur-nav');
    if (!nav) return;

    const cache = new WeakMap();
    let raf = null;

    // ---------- Helpers ----------
    function parseRGB(str) {
        if (!str) return null;
        const m = str.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
        if (m) return [Number(m[1]), Number(m[2]), Number(m[3]), m[4] ? Number(m[4]) : 1];
        if (str === 'transparent') return [255, 255, 255, 0];
        return null;
    }

    function brightness(rgb) {
        return 0.299 * rgb[0] + 0.587 * rgb[1] + 0.114 * rgb[2];
    }

    function extractUrl(bgImage) {
        const m = /url\(["']?([^"')]+)["']?\)/.exec(bgImage || '');
        return m ? m[1] : null;
    }

    function sampleImageAverageRGB(url) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = function () {
                try {
                    const size = 32;
                    const canvas = document.createElement('canvas');
                    canvas.width = size;
                    canvas.height = size;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, size, size);
                    const data = ctx.getImageData(0, 0, size, size).data;
                    let r = 0, g = 0, b = 0, count = data.length / 4;
                    for (let i = 0; i < data.length; i += 4) {
                        r += data[i]; g += data[i + 1]; b += data[i + 2];
                    }
                    resolve([r / count, g / count, b / count]);
                } catch (err) { reject(err); }
            };
            img.onerror = reject;
            img.src = url + (url.includes('?') ? '&' : '?') + 'cb=' + Date.now();
        });
    }

    function findBackgroundAncestor(el) {
        while (el && el !== document.documentElement) {
            const style = getComputedStyle(el);
            if (style.backgroundImage && style.backgroundImage !== 'none') return el;
            const bgColor = parseRGB(style.backgroundColor);
            if (bgColor && bgColor[3] > 0) return el;
            el = el.parentElement;
        }
        return document.body;
    }

    async function isSectionDark(section) {
        if (!section) return false;
        if (cache.has(section)) return cache.get(section);

        const override = section.getAttribute && section.getAttribute('data-nav-contrast');
        if (override === 'dark') { cache.set(section, true); return true; }
        if (override === 'light') { cache.set(section, false); return false; }

        try {
            const style = getComputedStyle(section);

            // Background image check
            if (style.backgroundImage && style.backgroundImage !== 'none') {
                const url = extractUrl(style.backgroundImage);
                if (url) {
                    try {
                        const rgb = await sampleImageAverageRGB(url);
                        const isDark = brightness(rgb) < 150;
                        cache.set(section, isDark);
                        return isDark;
                    } catch (e) {}
                }
            }

            const bg = parseRGB(style.backgroundColor);
            if (bg && bg[3] > 0) {
                const isDark = brightness(bg) < 150;
                cache.set(section, isDark);
                return isDark;
            }

            const anc = findBackgroundAncestor(section);
            if (anc && anc !== section) {
                const result = await isSectionDark(anc);
                cache.set(section, result);
                return result;
            }

            const txt = section.querySelector && section.querySelector('*');
            if (txt) {
                const c = parseRGB(getComputedStyle(txt).color);
                if (c) {
                    const isDark = brightness(c) < 150;
                    cache.set(section, isDark);
                    return isDark;
                }
            }
        } catch (err) {}

        cache.set(section, false);
        return false;
    }

    function elementUnderNavPoint() {
        const rect = nav.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.bottom + 2;
        nav.style.pointerEvents = 'none';
        const el = document.elementFromPoint(x, y) || document.body;
        nav.style.pointerEvents = '';
        return el;
    }

    // ---------- Main check ----------
    async function doCheck() {
        const el = elementUnderNavPoint();
        const section = el.closest('section, .elementor-section, .page-section, [data-nav-section]') || el;
        const style = getComputedStyle(section);
        const hasBgImage = style.backgroundImage && style.backgroundImage !== 'none';
        const dark = await isSectionDark(section);

        const navBg = getComputedStyle(nav).backgroundColor;
        const navRgb = parseRGB(navBg);
        const NAV_OPAQUE_ALPHA = 0.85; 
        const navIsOpaque = navRgb && navRgb[3] >= NAV_OPAQUE_ALPHA;
        const navIsNearlyWhite = navIsOpaque && brightness(navRgb) > 220; 

        if (navIsNearlyWhite) {
            nav.classList.remove('invert');
            nav.classList.add('nav-light-bg'); // dark items/logo
        } else if (hasBgImage || dark) {
            nav.classList.add('invert'); // white items/logo
            nav.classList.remove('nav-light-bg');
        } else {
            nav.classList.remove('invert');
            nav.classList.remove('nav-light-bg');
            if (nav.style.backgroundColor) nav.style.backgroundColor = ''; 
        }
    }

    function scheduleCheck() {
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => { doCheck().catch(()=>{}); });
    }

    // ---------- White navbar toggle ----------
    function toggleNavWhite(forceWhite) {
        if (forceWhite) {
            nav.style.backgroundColor = 'white';
        } else {
            nav.style.backgroundColor = '';
        }
        scheduleCheck();
    }

    document.querySelectorAll('.js-white-nav-trigger').forEach(icon => {
        icon.addEventListener('click', () => {
            const isCurrentlyWhite = nav.style.backgroundColor === 'white';
            toggleNavWhite(!isCurrentlyWhite);
        });
    });

    // ---------- Event listeners ----------
    window.addEventListener('scroll', scheduleCheck, { passive: true });
    window.addEventListener('resize', scheduleCheck);
    window.addEventListener('load', scheduleCheck);

    // Initial check
    setTimeout(scheduleCheck, 100);
    setTimeout(scheduleCheck, 500);
    setTimeout(scheduleCheck, 1200);
});</script> <script>// Only run on mobile screens
if (window.innerWidth <= 768) {
  // Select the dropdown menu
  const menuDropdowns = document.querySelectorAll('.e-n-menu-title.e-click');

  // Function to close a dropdown
  function closeDropdown(dropdown) {
    const content = dropdown.nextElementSibling; // The .e-n-menu-content
    if (content && content.classList.contains('e-active')) {
      content.classList.remove('e-active');
      dropdown.classList.remove('e-active');
    }
  }

  // Close dropdown on scroll
  let scrollTimeout;
  window.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      menuDropdowns.forEach(dropdown => closeDropdown(dropdown));
    }, 50); // debounce to avoid excessive firing
  });

  // Close dropdown when any content inside is clicked
  menuDropdowns.forEach(dropdown => {
    const content = dropdown.nextElementSibling;
    if (content) {
      content.addEventListener('click', e => {
        closeDropdown(dropdown);
      });
    }
  });
}</script> <div style="display:none"><div id='GetInTouchFormpop' style="padding:10px; background:#fff;"><div class="wpcf7 no-js" id="wpcf7-f26160-p27743-o1" lang="en-US" dir="ltr" data-wpcf7-id="26160"><div class="screen-reader-response"><p role="status" aria-live="polite" aria-atomic="true"></p><ul></ul></div><form action="/wp-content/uploads/2025/11/BLUE-RIDGE-LOGO.png#wpcf7-f26160-p27743-o1" method="post" class="wpcf7-form init" aria-label="Contact form" novalidate="novalidate" data-status="init"><fieldset class="hidden-fields-container"><input type="hidden" name="_wpcf7" value="26160" /><input type="hidden" name="_wpcf7_version" value="6.1.6" /><input type="hidden" name="_wpcf7_locale" value="en_US" /><input type="hidden" name="_wpcf7_unit_tag" value="wpcf7-f26160-p27743-o1" /><input type="hidden" name="_wpcf7_container_post" value="27743" /><input type="hidden" name="_wpcf7_posted_data_hash" value="" /></fieldset><div class="get-in-touch">
