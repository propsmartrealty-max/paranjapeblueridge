6da289b93e71f25ff25cfecf2ffe.css?ver=1f361' media='all' /> <script src="https://www.pscl.in/wp-includes/js/jquery/jquery.min.js?ver=3.7.1" id="jquery-core-js"></script> <script src="https://www.pscl.in/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1" id="jquery-migrate-js"></script> <script src="https://www.pscl.in/wp-content/plugins/wp-colorbox/jquery.colorbox-min.js?ver=1.1.6" id="colorbox-js"></script> <script src="https://www.pscl.in/wp-content/plugins/wp-colorbox/wp-colorbox.js?ver=1.1.6" id="wp-colorbox-js"></script> <link rel="https://api.w.org/" href="https://www.pscl.in/wp-json/" /><link rel="EditURI" type="application/rsd+xml" title="RSD" href="https://www.pscl.in/xmlrpc.php?rsd" /><meta name="generator" content="WordPress 6.9.4" /><meta name="generator" content="Elementor 4.1.4; features: e_font_icon_svg, additional_custom_breakpoints; settings: css_print_method-external, google_font-disabled, font_display-swap"> <script>document.addEventListener('DOMContentLoaded', function () {
  const nav = document.getElementById('blur-nav-m');
  if (!nav) return;

  let raf = null;
  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = 10;
  canvas.height = 10;

  function getBrightness(color) {
    if (!color) return 255;
    const m = color.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
    if (!m) return 255;
    const [r, g, b] = m.slice(1).map(Number);
    return 0.299 * r + 0.587 * g + 0.114 * b;
  }

  async function getEffectiveBrightness(el) {
    const style = getComputedStyle(el);
    const bgColor = style.backgroundColor;
    const bgImage = style.backgroundImage;

    // If background image exists, sample it
    if (bgImage && bgImage !== 'none') {
      const urlMatch = bgImage.match(/url\(["']?(.*?)["']?\)/);
      if (urlMatch) {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.src = urlMatch[1];

        try {
          await img.decode();
          ctx.clearRect(0, 0, 10, 10);
          ctx.drawImage(img, 0, 0, 10, 10);
          const data = ctx.getImageData(0, 0, 10, 10).data;
          let total = 0;
          for (let i = 0; i < data.length; i += 4) {
            total += 0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2];
          }
          return total / (data.length / 4);
        } catch (e) {
          // fallback to color if image can't be read
          return getBrightness(bgColor);
        }
      }
    }

    // climb up until a non-transparent color is found
    let current = el;
    while (current && current !== document.documentElement) {
      const bg = getComputedStyle(current).backgroundColor;
      if (bg && !bg.includes('rgba(0, 0, 0, 0)') && bg !== 'transparent') {
        return getBrightness(bg);
      }
      current = current.parentElement;
    }

    return 255; // default (light)
  }

  async function updateHeaderColor() {
    if (raf) cancelAnimationFrame(raf);
    raf = requestAnimationFrame(async () => {
      const rect = nav.getBoundingClientRect();
      const y = rect.bottom;
      const elementBehind = document.elementFromPoint(window.innerWidth / 2, y + 1);
      if (!elementBehind) return;

      const brightness = await getEffectiveBrightness(elementBehind);

      if (brightness < 130) {
        nav.style.backgroundColor = 'white';
      } else {
        nav.style.backgroundColor = '';
      }
    });
  }

  document.addEventListener('scroll', updateHeaderColor, { passive: true });
  window.addEventListener('resize', updateHeaderColor);
  window.addEventListener('load', updateHeaderColor);

  setTimeout(updateHeaderColor, 200);
  setTimeout(updateHeaderColor, 800);
  setTimeout(updateHeaderColor, 1500);

  updateHeaderColor();
});</script> <style>#blur-nav-m {
  transition: background-color 0.3s ease;
  background-color: transparent; /* default */
