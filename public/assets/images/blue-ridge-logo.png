  function lockBody() {
    const scrollY = window.scrollY || window.pageYOffset;
    document.documentElement.style.setProperty('--scroll-y', scrollY);
    document.body.style.position = 'fixed';
    document.body.style.top = `-${scrollY}px`;
    document.body.style.width = '100%';
  }
  function unlockBody() {
    const scrollY = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--scroll-y')) || 0;
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.width = '';
    window.scrollTo(0, scrollY);
  }

  // Observe body class changes — when popup class is added/removed
  const observer = new MutationObserver(muts => {
    muts.forEach(m => {
      if (m.attributeName === 'class') {
        const hasPopup = document.body.classList.contains('elementor-popup-modal-active') ||
                         document.body.classList.contains('elementor-popup-modal-open');
        if (hasPopup) lockBody();
        else unlockBody();
      }
    });
  });
  observer.observe(document.body, { attributes: true });
})();</script> </div></div></div></div><div data-elementor-type="popup" data-elementor-id="25241" class="elementor elementor-25241 elementor-location-popup" data-elementor-settings="{&quot;entrance_animation&quot;:&quot;fadeIn&quot;,&quot;exit_animation&quot;:&quot;fadeIn&quot;,&quot;entrance_animation_duration&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:0.5,&quot;sizes&quot;:[]},&quot;a11y_navigation&quot;:&quot;yes&quot;,&quot;timing&quot;:[]}" data-elementor-post-type="elementor_library"><div class="elementor-element elementor-element-6681b92 e-flex e-con-boxed e-con e-parent" data-id="6681b92" data-element_type="container" data-e-type="container"><div class="e-con-inner"><div class="elementor-element elementor-element-5387345 elementor-widget elementor-widget-html" data-id="5387345" data-element_type="widget" data-e-type="widget" data-widget_type="html.default"><form id="teleForm" class="custom-lead-form">
<label>Project:</label>
<select id="projectTele" required><option value="">Select Project</option><option value="athashri-b3">Athashri B3</option><option value="highgardens">Highgardens</option><option value="misty-greens">Misty Greens</option><option value="highlands">Highlands</option><option value="the-cove">The Cove</option><option value="the-rivolo-residences">The Rivolo Residences</option><option value="athashri-ananda">Athashri Ananda</option><option value="the-ridges-41">The Ridges 41</option><option value="altius">Altius</option><option value="trident-business-park">Trident Business Park</option><option value="trident-apartments">Trident Apartments</option><option value="happiness-hub">Happiness Hub</option><option value="samara-hills">Samara Hills</option><option value="the-orchard-residencies">The Orchard Residencies</option><option value="canopy">Canopy</option><option value="gloria-grand">Gloria Grand</option><option value="shrivega">Shrivega</option><option value="forest-trails">Forest Trails</option><option value="promenade-residences">Promenade Residences</option><option value="swaniketan">Swaniketan</option><option value="athashri-vadodara">Athashri Vadodara</option><option value="cove-residences">Cove Residences</option>
</select><input type="text" id="TeleFirstName" placeholder="Full Name" required>
<input type="email" id="TeleEmail" placeholder="Email" required>
<input type="tel" id="TeleMobileNo" placeholder="Mobile No" required><br><br><button type="button" id="btnTelecall">Submit</button></form> <script>(function () {
  const ajaxUrl = "/wp-admin/admin-ajax.php";

  // Auto-select project from ACF
  document.addEventListener("DOMContentLoaded", function () {
    if (window.preselectedProject) {
      const sel = document.getElementById("projectTele");
      sel.value = window.preselectedProject;
      sel.style.display = "none";
      
    }
  });

  function sendTelecalling() {
    const projectSel = document.getElementById("projectTele");
    const project = window.preselectedProject || projectSel.value;

    const FirstName = document.getElementById("TeleFirstName").value.trim();
    const Email = document.getElementById("TeleEmail").value.trim();
    const MobileNo = document.getElementById("TeleMobileNo").value.trim();



    if (!project || !FirstName || !Email || !MobileNo) {
      alert("Please fill all required fields.");
      return;
    }

    const fd = new FormData();
    fd.append("action", "send_to_mdocbox");
    fd.append("project", project);
    fd.append("dataFrom", "T");
    fd.append("FirstName", FirstName);
    fd.append("Email", Email);
    fd.append("MobileNo", MobileNo);

    fetch(ajaxUrl, { method: "POST", body: fd })
      .then(r => r.json())
      .then(data => {
        
        if (data.decoded?.status === "success") {
          alert("✅ Lead Submitted!");
          document.getElementById("teleForm").reset();
        } else {
          alert("Email or Mobile already used");
        }
      });
  }

  document.getElementById("btnTelecall")
    .addEventListener("click", sendTelecalling);
